{
  "version": 2,
  "builds": [
    {
      "src": "DoctorX/wsgi.py",
      "use": "@vercel/python",
      "config": {
        "srcCommand": "pip install -r requirements.txt && python manage.py migrate && python manage.py collectstatic --noinput --clear"
      }
    },
    {
      "src": "staticfiles/**/*",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    {
      "src": "/static/(.*)",
      "dest": "/static/$1"
    },
    {
      "src": "/media/(.*)",
      "dest": "/media/$1"
    },
    {
      "src": "/(.*)",
      "dest": "DoctorX/wsgi.py"
    }
  ],
  "env": {
    "DJANGO_SETTINGS_MODULE": "DoctorX.settings",
    "VERCEL": "1",
    "VERCEL_ENV": "production"
  },
  "functions": {
    "DoctorX/wsgi.py": {
      "runtime": "python3.9"
    }
  }
}
