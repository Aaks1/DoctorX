{
  "version": 2,
  "builds": [
    {
      "src": "api/index.py",
      "use": "@vercel/python",
      "config": {
        "maxLambdaSize": "15mb",
        "runtime": "python3.9"
      }
    }
  ],
  "routes": [
    {
      "src": "/static/(.*)",
      "dest": "/static/$1"
    },
    {
      "src": "/media/(.*)",
      "dest": "/media/$1"
    },
    {
      "src": "/(.*)",
      "dest": "api/index.py"
    }
  ],
  "env": {
    "DJANGO_SETTINGS_MODULE": "DoctorX.settings",
    "USE_NEON": "true",
    "PYTHONPATH": "/vercel/path0"
  },
  "build": {
    "env": {
      "DJANGO_SETTINGS_MODULE": "DoctorX.settings",
      "USE_NEON": "true",
      "PYTHONPATH": "/vercel/path0"
    }
  },
  "installCommand": "pip install -r requirements.txt",
  "buildCommand": "python manage.py migrate",
  "outputDirectory": "staticfiles"
}
