{
  "version": 2,
  "builds": [
    {
      "src": "DoctorX/wsgi.py",
      "use": "@vercel/python",
      "config": {
        "srcCommand": "pip install -r requirements.txt && python manage.py migrate && python manage.py collectstatic --noinput"
      }
    }
  ],
  "routes": [
    {
      "src": "/static/(.*)",
      "dest": "/static/$1"
    },
    {
      "src": "/(.*)",
      "dest": "DoctorX/wsgi.py"
    }
  ],
  "env": {
    "DJANGO_SETTINGS_MODULE": "DoctorX.settings",
    "VERCEL": "1",
    "VERCEL_ENV": "production"
  }
}
