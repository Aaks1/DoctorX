    "SECRET_KEY": "django-insecure-h%w_r)+r4_dp4$20+^cu=70k$miegazaf44dwr*t2_hfsk3m+q",
    "DEBUG": "false",
    "ALLOWED_HOSTS": "*.vercel.app,doctorx-doctoraaks1.vercel.app",
    "CSRF_TRUSTED_ORIGINS": "https://*.vercel.app,https://doctorx-doctoraaks1.vercel.app"
  },
  "build": {
    "env": {
      "DJANGO_SETTINGS_MODULE": "DoctorX.settings",
